<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Bind the public API contract to the composite provider so any caller
         can resolve StructuredDataProviderInterface from the ObjectManager. -->
    <preference for="Panth\StructuredData\Api\StructuredDataProviderInterface"
                type="Panth\StructuredData\Model\StructuredData\Composite"/>

    <!--
        Composite structured data provider. Providers contributed here produce
        schema.org JSON-LD nodes that the Aggregator deduplicates into a
        single @graph. Provider list is shared with the Aggregator type below
        so that both the Composite (used by ObjectManager callers) and the
        underlying Aggregator (used directly by the ViewModel) yield the same
        output.
    -->
    <type name="Panth\StructuredData\Model\StructuredData\Composite">
        <arguments>
            <argument name="providers" xsi:type="array">
                <item name="organization" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\OrganizationProvider</item>
                <item name="website" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\WebsiteProvider</item>
                <item name="breadcrumb" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\BreadcrumbProvider</item>
                <item name="product" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ProductProvider</item>
                <item name="faq" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\FaqExtractor</item>
                <item name="review" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ReviewProvider</item>
                <item name="video" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\VideoProvider</item>
                <item name="article" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\CmsArticleProvider</item>
                <item name="return_policy" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ReturnPolicyProvider</item>
                <item name="brand" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\BrandProvider</item>
                <item name="productList" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ProductListProvider</item>
                <item name="paymentMethod" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\PaymentMethodProvider</item>
                <item name="deliveryMethod" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\DeliveryMethodProvider</item>
                <item name="multiRegionShipping" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\MultiRegionShippingProvider</item>
                <item name="configurableOffer" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ConfigurableOfferProvider</item>
                <item name="groupedOffer" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\GroupedOfferProvider</item>
                <item name="bundleOffer" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\BundleOfferProvider</item>
                <item name="customProperties" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\CustomPropertiesProvider</item>
                <item name="energyLabel" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\EnergyLabelProvider</item>
                <item name="certification" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\CertificationProvider</item>
                <item name="saleEvent" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\SaleEventProvider</item>
                <item name="productGroup" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ProductGroupProvider</item>
                <item name="prosCons" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ProsConsProvider</item>
                <item name="seller" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\SellerProvider</item>
            </argument>
            <argument name="validator" xsi:type="object">Panth\StructuredData\Model\StructuredData\Validator</argument>
        </arguments>
    </type>

    <type name="Panth\StructuredData\Model\StructuredData\Aggregator">
        <arguments>
            <argument name="providers" xsi:type="array">
                <item name="organization" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\OrganizationProvider</item>
                <item name="website" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\WebsiteProvider</item>
                <item name="breadcrumb" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\BreadcrumbProvider</item>
                <item name="product" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ProductProvider</item>
                <item name="faq" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\FaqExtractor</item>
                <item name="review" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ReviewProvider</item>
                <item name="video" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\VideoProvider</item>
                <item name="article" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\CmsArticleProvider</item>
                <item name="return_policy" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ReturnPolicyProvider</item>
                <item name="brand" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\BrandProvider</item>
                <item name="productList" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ProductListProvider</item>
                <item name="paymentMethod" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\PaymentMethodProvider</item>
                <item name="deliveryMethod" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\DeliveryMethodProvider</item>
                <item name="multiRegionShipping" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\MultiRegionShippingProvider</item>
                <item name="configurableOffer" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ConfigurableOfferProvider</item>
                <item name="groupedOffer" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\GroupedOfferProvider</item>
                <item name="bundleOffer" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\BundleOfferProvider</item>
                <item name="customProperties" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\CustomPropertiesProvider</item>
                <item name="energyLabel" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\EnergyLabelProvider</item>
                <item name="certification" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\CertificationProvider</item>
                <item name="saleEvent" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\SaleEventProvider</item>
                <item name="productGroup" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ProductGroupProvider</item>
                <item name="prosCons" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\ProsConsProvider</item>
                <item name="seller" xsi:type="object">Panth\StructuredData\Model\StructuredData\Provider\SellerProvider</item>
            </argument>
            <argument name="validator" xsi:type="object">Panth\StructuredData\Model\StructuredData\Validator</argument>
        </arguments>
    </type>

    <!-- Blog detector: supported blog post model FQCNs (soft dependencies).
         These are optional runtime-probed classes; none are Panth code. -->
    <type name="Panth\StructuredData\Model\Blog\BlogDetector">
        <arguments>
            <argument name="supportedClasses" xsi:type="array">
                <item name="blog_adapter_1" xsi:type="string">Magefan\Blog\Model\Post</item>
                <item name="blog_adapter_2" xsi:type="string">Mirasvit\Blog\Model\Post</item>
                <item name="blog_adapter_3" xsi:type="string">Mageplaza\Blog\Model\Post</item>
            </argument>
        </arguments>
    </type>

    <!-- Remove native JSON-LD markup from Magento on targeted blocks. -->
    <type name="Magento\Framework\View\Element\AbstractBlock">
        <plugin name="panth_structured_data_remove_native_markup"
                type="Panth\StructuredData\Plugin\StructuredData\RemoveNativeMarkupPlugin"
                sortOrder="15"/>
    </type>

    <!-- Breadcrumb priority plugin: reorder product breadcrumbs by config. -->
    <type name="Magento\Catalog\Helper\Data">
        <plugin name="panth_structured_data_breadcrumb_priority"
                type="Panth\StructuredData\Plugin\Breadcrumb\BreadcrumbPlugin"
                sortOrder="10"/>
    </type>

    <!-- Inject the breadcrumbs_priority field into the category admin form. -->
    <type name="Magento\Catalog\Model\Category\DataProvider">
        <plugin name="panth_structured_data_category_form_priority"
                type="Panth\StructuredData\Plugin\Breadcrumb\CategoryFormPriorityPlugin"
                sortOrder="10"/>
    </type>

</config>
