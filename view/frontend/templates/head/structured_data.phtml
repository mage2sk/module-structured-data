<?php
/** @var \Panth\StructuredData\Block\Head\StructuredData $block */
/** @var \Magento\Framework\Escaper $escaper */

if (!$block->isEnabled()) {
    return;
}
$json = $block->getJson();
if ($json === '') {
    return;
}
// The Aggregator already escapes </script> inside the JSON payload.
// We output the JSON directly — no additional escaping needed here.
?>
<script type="application/ld+json" data-panth-seo="jsonld"><?= /* @noEscape */ $json ?></script>
